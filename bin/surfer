#!/usr/bin/env python3
"""`surfer` executable. Symlinked onto PATH; resolves its real location so the
history_surfer package is importable regardless of the symlink."""

import os
import sys

_real = os.path.realpath(__file__)
_root = os.path.dirname(os.path.dirname(_real))
if _root not in sys.path:
    sys.path.insert(0, _root)

from history_surfer import cli

if __name__ == "__main__":
    sys.exit(cli.main())
